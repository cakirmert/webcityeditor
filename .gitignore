# Dependencies
node_modules/
/node_modules/
prototype/node_modules/
spike/cityjson-threejs-loader/node_modules/

# The cityjson-threejs-loader is a third-party clone — don't commit their source
# as ours. Users run the setup step in README.md to clone it themselves.
spike/cityjson-threejs-loader/

# Build output
prototype/dist/
prototype/.vite/
spike/cityjson-threejs-loader/dist/
spike/unpacked/
unpacked_v*/

# Test + coverage
prototype/coverage/
*.test.log

# Environment
.env
.env.local
.env.*.local

# Editor + IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Temporary / generated
*.log
*.tmp
~$*.docx
~$*.xlsx

# Local test data (CityGML / CityJSON / large fixtures) — users bring their own
Data/
data/
*.gml
*.GML
*.city.json
*.city.jsonl
*.jsonl
# keep the built-in sample cube in source tests unaffected — none on disk

# Third-party CLI tools downloaded during setup (citygml-tools, citydb-tool, …)
tools/

# Local demo folder — see demo/README.md. Sample IFCs and CityJSON tiles
# get downloaded here for in-person demos; they're public-domain test
# fixtures but we don't want to bloat the repo with binaries.
demo/

# Browser-driven test artefacts. The dev server serves /public for fetch
# during in-browser demos; we stage demo .ifc / .city.json here when
# automating the flow but they're never source. Vite's vite-env.d.ts +
# any TS files in /public stay tracked (none today).
.ifc-test/
.docx-build/
.docx-extract/
prototype/public/*.ifc
prototype/public/*.city.json
prototype/public/*.city.jsonl
